APP_NAME=CustomGram
APP_BUNDLE_ID=app.customgram.client
APP_SPECIFIC_URL_SCHEME=customgram

GLOBAL_CONSTANTS = APP_CONFIG_IS_INTERNAL_BUILD=false APP_CONFIG_IS_APPSTORE_BUILD=true APP_CONFIG_APPSTORE_ID=0 APP_SPECIFIC_URL_SCHEME="\"$(APP_SPECIFIC_URL_SCHEME)\""
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) $(GLOBAL_CONSTANTS)

GCC_PREPROCESSOR_DEFINITIONS = $(inherited) APP_CONFIG_API_ID=0 APP_CONFIG_API_HASH="\"PUT_YOUR_API_HASH_FROM_MY_TELEGRAM_ORG\"" APP_CONFIG_HOCKEYAPP_ID="\"\""
